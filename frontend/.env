# API Configuration
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# Environment
VITE_ENV=development

# ── ngrok / external testing ──────────────────────────────────────────────
# When testing with ngrok, expose both ports and set these variables:
#
#   Terminal 1:  ngrok http 3000   → copy HTTPS URL → VITE_APP_URL
#   Terminal 2:  ngrok http 5000   → copy HTTPS URL → VITE_API_URL + VITE_SOCKET_URL
#
# Then restart the dev server (npm run dev) for changes to take effect.
#
# VITE_APP_URL=https://xxxx-frontend.ngrok-free.app
# VITE_API_URL=https://xxxx-backend.ngrok-free.app
# VITE_SOCKET_URL=https://xxxx-backend.ngrok-free.app
