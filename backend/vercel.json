{
  "version": 2,
  "name": "ai-interview-maker-backend",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "_DEPLOY_WARNING": "Socket.io requires a persistent server. Use Render/Railway/Fly.io for backend — NOT Vercel serverless."
  },
  "regions": ["iad1"]
}
