# Production Environment Configuration
# Copy this file to .env.production and fill in the actual values

# Server Configuration
PORT=3000
NODE_ENV=production

# Gemini AI Configuration
GEMINI_API_KEY=your_production_gemini_api_key_here

# Authentication
JWT_SECRET=your_production_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database Configuration
# MongoDB Atlas (Recommended for production)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/ai-interview-maker?retryWrites=true&w=majority

# PostgreSQL on AWS RDS (Alternative)
# DATABASE_URL=postgresql://username:password@your-rds-endpoint.region.rds.amazonaws.com:5432/ai_interview_maker

# CORS Configuration
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# File Upload & Storage
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# AWS S3 Configuration (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-interview-maker-files

# Google Cloud Storage (Alternative to S3)
# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET=ai-interview-maker-files
# GCS_KEYFILE_PATH=./gcs-keyfile.json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Logging
LOG_LEVEL=info

# Security
HELMET_ENABLED=true
TRUST_PROXY=true
